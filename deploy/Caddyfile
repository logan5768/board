# Caddy конфиг для board.spirtvpn.ru
# 443 на этом VDS занят xray (VPN). Поэтому сайт живёт на нестандартном порту 8443.
# Порт 80 свободен и используется Caddy для ACME HTTP-01 (выпуск Let's Encrypt cert)
# + редиректа http://board.spirtvpn.ru → https://board.spirtvpn.ru:8443
# UDP 8443 занят hysteria (тоже VPN), поэтому глобально выключаем HTTP/3 (QUIC) —
# работаем только по TCP. На функциональность не влияет.
#
# Раскладка: всё лежит в /srv/aiboard (там же git-репозиторий проекта).
# Caddy раздаёт статику оттуда; proxy.py, deploy-файлы и .git скрыты от веба.

{
    servers {
        protocols h1 h2
    }
}

# Главный сайт — нестандартный порт 8443
board.spirtvpn.ru:8443 {
    encode zstd gzip

    # /v1/* -> локальный CORS-прокси, который проксирует на api.zenoid.space
    handle /v1/* {
        reverse_proxy 127.0.0.1:8787 {
            transport http {
                read_timeout 180s
                write_timeout 180s
            }
        }
    }

    # Статика aiboard (index.html, test-api.html). Source и системные файлы скрыты.
    handle {
        root * /srv/aiboard
        file_server {
            hide proxy.py deploy/* *.sh *.bat .git/* .gitignore README* LICENSE*
        }
    }

    log {
        output file /var/log/caddy/board.spirtvpn.ru.log
        format console
    }
}

# Порт 80: 1) ACME HTTP-01 (Caddy сам подхватит), 2) редирект на :8443
http://board.spirtvpn.ru {
    redir https://{host}:8443{uri} permanent
}
